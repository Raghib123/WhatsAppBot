# Gemini API Key - ambil dari https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Prefix untuk trigger image generation (default: /image)
IMAGE_PREFIX=/image

# Prefix untuk trigger text chat (default: kosong = semua pesan)
# Kalau mau semua pesan ke AI, kosongin aja
CHAT_PREFIX=

# Max history per user (biar ga makan memory)
MAX_HISTORY=10
